# Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=supersecretpassword
POSTGRES_DB=blog
POSTGRES_PORT=5432

# Runtime
BLOG_RUNTIME_ENV=local

# HTTP
BLOG_HTTP_PORT=8080
BLOG_HTTP_READ_HEADER_TIMEOUT=5s
BLOG_HTTP_READ_TIMEOUT=5s
BLOG_HTTP_WRITE_TIMEOUT=10s
BLOG_HTTP_IDLE_TIMEOUT=120s
BLOG_HTTP_MAX_HEADER_BYTES=1048576

# Database
BLOG_DB_URL=postgres://admin:supersecretpassword@postgres:5432/blog?sslmode=disable
BLOG_DB_MAX_CONNS=10
BLOG_DB_MIN_CONNS=2
BLOG_DB_MAX_CONN_LIFETIME=1h
BLOG_DB_MAX_CONN_IDLE_TIME=30m

# JWT
BLOG_JWT_SECRET=change-me-in-production
BLOG_JWT_TTL=24h
BLOG_JWT_ISSUER=blog

# Log
BLOG_LOG_LEVEL=info
BLOG_LOG_FORMAT=json

# Grafana
GRAFANA_ADMIN_PASSWORD=changeme
